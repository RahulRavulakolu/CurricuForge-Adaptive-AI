# Copy this file to .env and set your OpenAI API key
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY
PORT=3001

# Optional: Groq settings. If both GROQ_API_KEY and GROQ_API_URL are set, the proxy will forward requests to Groq.
# Example GROQ_API_URL may look like https://api.groq.ai/v1/models/<model>/infer
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_KEY
GROQ_API_URL=https://api.groq.com/openai/v1
